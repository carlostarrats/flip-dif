{
  "name": "flip",
  "version": "0.1.0",
  "type": "module",
  "bin": { "flip": "./bin/flip.mjs" },
  "scripts": {
    "build": "tsc -p . && node scripts/copy-public.mjs",
    "dev": "tsc -p . --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:all": "RUN_PUPPETEER=1 RUN_E2E=1 RUN_UI_E2E=1 RUN_VISUAL=1 RUN_LIFECYCLE_E2E=1 RUN_FRAMEWORK_E2E=1 RUN_BURST_E2E=1 vitest run",
    "test:ui": "RUN_UI_E2E=1 vitest run tests/viewer/ui.e2e.test.ts",
    "test:visual": "RUN_VISUAL=1 vitest run tests/visual",
    "test:visual:bless": "UPDATE_BASELINE=1 RUN_VISUAL=1 vitest run tests/visual",
    "test:lifecycle": "RUN_LIFECYCLE_E2E=1 vitest run tests/lifecycle/multi-session.test.ts",
    "test:framework": "RUN_FRAMEWORK_E2E=1 vitest run tests/lifecycle/framework.test.ts",
    "test:burst": "RUN_BURST_E2E=1 vitest run tests/lifecycle/burst.test.ts",
    "lint": "eslint src tests",
    "format": "prettier --write src tests"
  },
  "engines": { "node": ">=20" },
  "dependencies": {
    "puppeteer": "^23.0.0",
    "pixelmatch": "^6.0.0",
    "pngjs": "^7.0.0",
    "simple-git": "^3.25.0",
    "chokidar": "^3.6.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "@types/node": "^20.0.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0"
  }
}
